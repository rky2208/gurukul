# Copy to .env for local overrides. Not needed in dev (the Vite dev server
# proxies /api to the backend — see vite.config.ts).
#
# In production, point this at your deployed backend's origin (no trailing
# slash, no /api suffix — that's added automatically):
# VITE_API_URL=https://api.gurukul.app

# The model dropdown and "show thinking" toggle are dev/debug controls.
# They're on automatically when running `npm run dev` and off in a
# production build. Set this to force them on in a production build too
# (e.g. a staging deploy where you still want to see them):
# VITE_SHOW_DEV_CONTROLS=true